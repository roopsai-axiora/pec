### 1. Create Rule - High Achiever
POST {{baseUrl}}/api/rules
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "High Achiever Bonus",
  "description": "Achievement greater than 90%",
  "operator": "GT",
  "thresholdValue": 90.00,
  "action": "ADD",
  "actionValue": 10.00,
  "priority": 1
}

### 2. Create Rule - Average Performer
POST {{baseUrl}}/api/rules
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Average Performer",
  "description": "Achievement between 70% and 90%",
  "operator": "BETWEEN",
  "thresholdValue": 70.00,
  "thresholdValueUpper": 90.00,
  "action": "MULTIPLY",
  "actionValue": 0.80,
  "priority": 2
}

### 3. Create Rule - Low Performer
POST {{baseUrl}}/api/rules
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Low Performer",
  "description": "Achievement less than 50%",
  "operator": "LT",
  "thresholdValue": 50.00,
  "action": "DISQUALIFY",
  "actionValue": 0.00,
  "priority": 3
}

### 4. Get All Rules
GET {{baseUrl}}/api/rules
Authorization: Bearer {{token}}

### 5. Get Active Rules
GET {{baseUrl}}/api/rules/active
Authorization: Bearer {{token}}

### 6. Get Rule by ID
GET {{baseUrl}}/api/rules/1
Authorization: Bearer {{token}}

### 7. Update Rule
PUT {{baseUrl}}/api/rules/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "High Achiever Bonus Updated",
  "description": "Achievement greater than 95%",
  "operator": "GT",
  "thresholdValue": 95.00,
  "action": "ADD",
  "actionValue": 15.00,
  "priority": 1
}

### 8. Deactivate Rule
PATCH {{baseUrl}}/api/rules/1/deactivate
Authorization: Bearer {{token}}

### 9. Activate Rule
PATCH {{baseUrl}}/api/rules/1/activate
Authorization: Bearer {{token}}

### 10. Duplicate priority (500)
POST {{baseUrl}}/api/rules
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Duplicate",
  "operator": "GT",
  "thresholdValue": 80.00,
  "action": "ADD",
  "actionValue": 5.00,
  "priority": 1
}

### 11. BETWEEN without upper bound (500)
POST {{baseUrl}}/api/rules
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Invalid BETWEEN",
  "operator": "BETWEEN",
  "thresholdValue": 70.00,
  "action": "ADD",
  "actionValue": 5.00,
  "priority": 4
}

### Create Rule - null threshold (should fail 500)
POST http://localhost:8080/api/rules
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Invalid Rule",
  "operator": "GT",
  "thresholdValue": null,
  "action": "ADD",
  "actionValue": 10.00,
  "priority": 5
}

### Create Rule - negative threshold (should fail 500)
POST http://localhost:8080/api/rules
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Invalid Rule",
  "operator": "GT",
  "thresholdValue": -10.00,
  "action": "ADD",
  "actionValue": 10.00,
  "priority": 5
}

### Create Rule - BETWEEN upper less than lower (should fail 500)
POST http://localhost:8080/api/rules
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Invalid BETWEEN",
  "operator": "BETWEEN",
  "thresholdValue": 90.00,
  "thresholdValueUpper": 70.00,
  "action": "ADD",
  "actionValue": 10.00,
  "priority": 5
}

