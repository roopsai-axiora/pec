        {
          "name": "Resolve Manager IDs From Audit",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "const byEmail = (email) => data.find(log => (log.details || '').includes(email));",
                  "const managerOne = byEmail(pm.environment.get('managerOneEmail'));",
                  "const managerTwo = byEmail(pm.environment.get('managerTwoEmail'));",
                  "if (managerOne) pm.environment.set('managerOneId', managerOne.entityId);",
                  "if (managerTwo) pm.environment.set('managerTwoId', managerTwo.entityId);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/audit/action/USER_REGISTERED",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
